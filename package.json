{
  "name": "ui-explorer",
  "version": "0.0.1",
  "private": true,
  "description": "Electron + React UI Explorer workspace for inspecting web UI targets.",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsc -p tsconfig.electron.json --watch\" \"vite --host 127.0.0.1\" \"wait-on dist-electron/main/main.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main/main.js\"",
    "dev:electron": "tsc -p tsconfig.electron.json --watch",
    "build": "tsc -p tsconfig.electron.json && tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.electron.json && tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .tmp-tests/**/*.test.js",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
